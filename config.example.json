{
  "hotkeys": {
    "toggle": "f2"
  },
  "audio": {
    "sample_rate": 16000,
    "block_ms": 20,
    "device": null,
    "max_session_bytes": 20971520
  },
  "vad": {
    "start_threshold": 0.02,
